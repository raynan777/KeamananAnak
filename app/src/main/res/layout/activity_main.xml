<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F0F4FF" android:padding="16dp">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_horizontal">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🛡️ KEAMANAN ANAK" android:textSize="26sp" android:textStyle="bold" android:gravity="center" android:textColor="#1A237E" android:padding="16dp"/>
        <TextView android:id="@+id/txtBattery" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔋 Baterai: Loading..." android:textSize="16sp" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        <TextView android:id="@+id/txtLocation" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📍 Lokasi: Belum aktif" android:textSize="16sp" android:background="#FFFFFF" android:padding="16dp" android:layout_marginBottom="12dp" android:elevation="2dp"/>
        <Button android:id="@+id/btnGPS" android:layout_width="match_parent" android:layout_height="60dp" android:text="📍 CEK LOKASI SEKARANG" android:textSize="16sp" android:layout_marginBottom="12dp"/>
        <Button android:id="@+id/btnSOS" android:layout_width="match_parent" android:layout_height="80dp" android:text="🚨 TOMBOL SOS DARURAT" android:textSize="18sp" android:textStyle="bold" android:backgroundTint="#D32F2F" android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/txtInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Info HP..." android:textSize="14sp" android:background="#FFFFFF" android:padding="16dp" android:elevation="2dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Versi 3.0 FULL - By raynan777" android:gravity="center" android:padding="20dp" android:textSize="12sp"/>
    </LinearLayout>
</ScrollView>
